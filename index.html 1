// ── Listen for owner to approve/message ──
function listenForOwnerResponse(uid){
  if(_regUnsub) _regUnsub();
  log('info','Starting approval listener for',uid);

  _regUnsub=db.collection('approvedSchools').doc(uid)
    .onSnapshot(snap=>{
      if(!snap.exists) return;
      const d=snap.data();
      log('info','Approval status update received',d.status);

      if(d.status==='approved'){
        // ✅ AUTO-REDIRECT to admin dashboard
        log('info','APPROVED — redirecting to admin.html');
        
        // Update the waiting screen to show success
        const icon=el('screen4')?.querySelector('.sub-icon');
        if(icon) icon.textContent='🎉';
        const title=el('screen4')?.querySelector('.sub-title');
        if(title) title.textContent='Approved!';
        const msg=el('screen4')?.querySelector('.sub-msg');
        if(msg) msg.innerHTML='Your school has been approved! Redirecting to your dashboard...';

        // Redirect after 1.5 seconds
        setTimeout(()=>{ 
          window.location.href = 'admin.html';
        }, 1500);
        return;
      }

      if(d.status==='suspended'){
        showOwnerBanner('rejected',
          '🚫 Registration Not Approved',
          d.message||'Your registration was not approved. Please contact us on WhatsApp if you believe this is an error.',
          'https://wa.me/254704518130'
        );
        return;
      }

      // Pending with a new message from owner
      if(d.message && d.message.trim()){
        showOwnerBanner('pending','📩 Message from Administrator',d.message,d.contact||'https://wa.me/254704518130');
      }
    }, e=>log('error','Approval listener error',e.message));
}

function showOwnerBanner(type,title,msg,contact){
  el('obIcon').textContent=type==='approved'?'✅':'📩';
  el('obTitle').textContent=title;
  el('obMsg').textContent=msg;
  const banner=el('ownerBanner');
  banner.className=`owner-banner show ${type}`;
  if(contact){
    const wa=banner.querySelector('.ob-wa');
    if(wa) wa.href=contact;
  }
}

