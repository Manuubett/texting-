async function submitDetails(){
  const d=readDetails();
  if(!d.name){toast('School name is required','err');el('sName').focus();return;}
  if(!d.county){toast('Please select your county','err');return;}
  if(!d.principal){toast('Principal name is required','err');el('sPrincipal').focus();return;}
  if(!d.phone){toast('Phone number is required','err');el('sPhone').focus();return;}

  const uid = _createdUid || auth.currentUser?.uid;
  if(!uid){toast('Session expired — please create account again','err');goToStep(2);return;}
  if(!auth.currentUser){
    toast('Not authenticated — please create your account first','err');
    goToStep(2); return;
  }

  const btn=el('submitBtn'),txt=el('submitTxt');
  btn.disabled=true; txt.innerHTML='<div class="spin-sm"></div> Submitting…';
  log('info','Submitting school details',d.name);

  try{
    // Save school settings
    await db.collection('settings').doc(uid).set({
      ...d, schoolId:uid,
      updatedAt:firebase.firestore.FieldValue.serverTimestamp()
    },{merge:true});

    // Create/update approvedSchools doc
    const existingSnap = await db.collection('approvedSchools').doc(uid).get();
    if(!existingSnap.exists){
      await db.collection('approvedSchools').doc(uid).set({
        uid, schoolName:d.name,
        county:d.county, subCounty:d.subCounty||'',
        principal:d.principal, phone:d.phone,
        status:'pending',
        detectedAt:firebase.firestore.FieldValue.serverTimestamp()
      });
    } else {
      await db.collection('approvedSchools').doc(uid).update({
        schoolName:d.name,
        county:d.county, subCounty:d.subCounty||'',
        principal:d.principal, phone:d.phone,
        updatedAt:firebase.firestore.FieldValue.serverTimestamp()
      });
    }

    // Notify owner via ownerLog
    await db.collection('ownerLog').add({
      type:'new_registration',
      message:'New school registration awaiting approval: '+d.name+' ('+d.county+')',
      school:d.name, county:d.county||'',
      principal:d.principal||'', phone:d.phone||'',
      color:'amber',
      createdAt:firebase.firestore.FieldValue.serverTimestamp()
    });

    // Send notification via Vercel backend
    const apiKey = 'bett254'; // your TELEGRAM_API_KEY from Vercel
    const webhookUrl = 'https://telegram-bot6.vercel.app/api/send'; // replace with your actual Vercel URL

    fetch(webhookUrl, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'x-api-key': apiKey,
      },
      body: JSON.stringify({
        text: `🆕 <b>NEW SCHOOL REGISTRATION</b> 🆕\n\n` +
              `<b>🏫 School:</b> ${d.name}\n` +
              `<b>📍 County:</b> ${d.county || '—'}${d.subCounty ? ' (' + d.subCounty + ')' : ''}\n` +
              `<b>👤 Principal:</b> ${d.principal || '—'}\n` +
              `<b>📞 Phone:</b> ${d.phone || '—'}\n` +
              `<b>✉️ Email:</b> ${auth.currentUser?.email || '—'}\n` +
              `<b>⏰ Time:</b> ${new Date().toLocaleString('en-KE')}\n` +
              `<b>🆔 Ref:</b> <code>${uid.slice(0,12).toUpperCase()}</code>`,
        parseMode: 'HTML',
      }),
    })
      .then(res => res.json())
      .then(data => {
        if (!data.success) console.warn('Telegram notification failed');
      })
      .catch(err => console.warn('Telegram notification error:', err));

    localStorage.removeItem(SAVE_KEY);
    el('subRef').textContent=uid.slice(0,16).toUpperCase();
    log('info','Registration submitted successfully');

    // Listen for owner response
    listenForOwnerResponse(uid);
    goToStep(4);
    el('stepsBar').style.display='none';

  }catch(e){
    log('error','Submit failed',e.message);
    toast('Submit failed: '+e.message,'err');
    btn.disabled=false;
    txt.textContent='📤 Submit for Approval';
  }
}

