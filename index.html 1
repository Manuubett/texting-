// ── Returning user login ──
async function doLogin(){
  el('loginErr').classList.remove('show');
  const email=el('liEmail').value.trim();
  const pass=el('liPass').value;
  const remember=el('rememberMe').checked;
  if(!email||!pass){
    el('loginErrMsg').textContent='Email and password are required.';
    el('loginErr').classList.add('show'); return;
  }
  const btn=el('loginBtn'),txt=el('loginBtnTxt');
  btn.disabled=true; txt.innerHTML='<div class="spin-sm"></div> Signing in…';
  try{
    const persistence = remember
      ? firebase.auth.Auth.Persistence.LOCAL
      : firebase.auth.Auth.Persistence.SESSION;
    await auth.setPersistence(persistence);
    await auth.signInWithEmailAndPassword(email, pass);
    localStorage.setItem('cbe_reg_email', email);
    // onAuthStateChanged will handle redirect
  }catch(e){
    btn.disabled=false; txt.textContent='Sign In →';
    const msg = e.code==='auth/user-not-found'||e.code==='auth/wrong-password'||e.code==='auth/invalid-credential'
      ? 'Incorrect email or password.'
      : e.code==='auth/too-many-requests' ? 'Too many attempts. Try again later.'
      : e.message;
    el('loginErrMsg').textContent=msg;
    el('loginErr').classList.add('show');
    log('warn','Login failed',e.code);
  }
}

document.addEventListener('DOMContentLoaded',()=>{
  const lp=el('liPass');
  if(lp) lp.addEventListener('keydown',e=>{ if(e.key==='Enter') doLogin(); });
