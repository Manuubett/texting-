// CRITICAL FIX: Handle authenticated users properly
auth.onAuthStateChanged(async u=>{
  if(!u){
    // Not logged in — show appropriate screen based on step
    if(currentStep === 0) return; // stay on login screen
    if(currentStep >= 2 && currentStep <= 4){
      // User was in registration flow but got logged out
      log('warn','User logged out during registration flow');
      goToStep(0);
    }
    return;
  }

  log('info','User authenticated on register page',u.email);
  _createdUid=u.uid;

  try{
    // First check user role in users collection
    const userSnap = await db.collection('users').doc(u.uid).get();
    
    if(userSnap.exists){
      const userProfile = userSnap.data();
      
      // TEACHER FLOW: If user is a teacher
      if(userProfile.role === 'teacher'){
        log('info','Teacher user detected', userProfile.status);
        
        if(userProfile.status === 'active'){
          // Approved teacher — redirect to marksheet
          log('info','Approved teacher — redirecting to marksheet.html');
          window.location.href = 'marksheet.html';
          return;
        } else if(userProfile.status === 'pending'){
          // Pending teacher — show waiting message and sign out
          toast('⏳ Your teacher account is pending approval. Please wait for the administrator.', 'info');
          await auth.signOut();
          goToStep(0);
          return;
        } else if(userProfile.status === 'suspended'){
          toast('🚫 Your account has been suspended. Contact the administrator.', 'err');
          await auth.signOut();
          goToStep(0);
          return;
        }
      }
      
      // ADMIN FLOW: Check approvedSchools
      const snap = await db.collection('approvedSchools').doc(u.uid).get();

      if(snap.exists){
        const d = snap.data();

        if(d.status === 'approved'){
          // ✅ APPROVED ADMIN — redirect immediately
          log('info','Approved admin — redirecting to admin.html');
          window.location.href = 'admin.html';
          return;
        }

        if(d.status === 'suspended'){
          // Blocked — show message and sign out
          el('subRef').textContent = u.uid.slice(0,16).toUpperCase();
          goToStep(4);
          el('stepsBar').style.display = 'none';
          listenForOwnerResponse(u.uid);
          showOwnerBanner('rejected','🚫 Registration Not Approved',
            d.message || 'Your registration was not approved. Contact us on WhatsApp.',
            'https://wa.me/254704518130');
          return;
        }

        // Pending — show waiting screen, listen for approval
        log('info','Admin is pending — showing waiting screen');
        el('subRef').textContent = u.uid.slice(0,16).toUpperCase();
        goToStep(4);
        el('stepsBar').style.display = 'none';
        listenForOwnerResponse(u.uid);
        if(d.message && d.message.trim()){
          showOwnerBanner('pending','📩 Message from Administrator',d.message,d.contact || 'https://wa.me/254704518130');
        }
        return;
      }

      // No approvedSchools doc — check if they have settings
      const settSnap = await db.collection('settings').doc(u.uid).get();
      if(!settSnap.exists || !settSnap.data().name){
        // Has account but no school details yet
        log('info','Admin has no school details — go to step 3');
        goToStep(3);
        restoreSchoolDetails();
      } else {
        // Has settings but never submitted? This shouldn't happen, but just in case
        log('info','Admin has settings but no approvedSchools doc — go to step 4');
        goToStep(4);
        listenForOwnerResponse(u.uid);
      }
    } else {
      // User exists in Auth but not in users collection — shouldn't happen
      log('warn','User authenticated but no profile found', u.uid);
      await auth.signOut();
      goToStep(0);
    }

  } catch(e){ 
    log('error','Auth state check failed',e.message);
    // On error, show login screen
    goToStep(0);
  }
});

