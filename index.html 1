}

// ── Toast ──
function toast(msg,type='ok'){
  const t=document.createElement('div');t.className=`t ${type}`;
  t.innerHTML=`<span>${type==='ok'?'✅':'❌'}</span>${msg}`;
  el('tc').appendChild(t);
  setTimeout(()=>{t.style.animation='tout .25s ease forwards';setTimeout(()=>t.remove(),280);},3200);
}

